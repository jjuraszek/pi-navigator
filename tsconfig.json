{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2023"],
    "types": ["node"],
    "strict": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "paths": { "typebox": ["./node_modules/@sinclair/typebox/build/cjs/index.d.ts"] }
  },
  "include": ["index.ts", "src/**/*.ts", "eval/**/*.ts"],
  "exclude": ["src/**/__fixtures__/**"]
}
